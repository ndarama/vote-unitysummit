generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(uuid())
  title       String
  description String
  imageUrl    String
  nominees    Nominee[]
  votes       Vote[]
}

model Nominee {
  id              String   @id @default(uuid())
  categoryId      String
  name            String
  title           String
  description     String
  imageUrl        String
  withdrawn       Boolean  @default(false)
  withdrawalNote  String?
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  votes           Vote[]
}

model Vote {
  id                 String   @id @default(uuid())
  email              String
  categoryId         String
  nomineeId          String
  timestamp          BigInt
  ip                 String?
  userAgent          String?
  anomalyScore       Int?     @default(0)
  flagged            Boolean  @default(false)
  invalid            Boolean  @default(false)
  invalidationReason String?
  category           Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  nominee            Nominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)

  @@unique([email, categoryId])
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
  role     String
}

model Voter {
  id        String @id @default(uuid())
  email     String @unique
  name      String
  invitedAt BigInt
}

model AuditLog {
  id        String @id @default(uuid())
  timestamp BigInt
  type      String
  severity  String
  message   String
  metadata  Json?
}

model SystemConfig {
  key   String @id
  value Json
}

model OTP {
  email   String @id
  code    String
  expires BigInt
}
